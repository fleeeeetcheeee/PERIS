# Copy to .env and fill in. All keys are free-tier; the system runs without them
# but with degraded sources/gates. Verify with: uv run python -m ingestion.check_keys

# Tiingo — primary EOD prices (dividend-adjusted). https://www.tiingo.com/account/api/token
TIINGO_API_KEY=

# Finnhub — earnings calendar; activates the earnings-exclusion gate.
# https://finnhub.io/dashboard (register, key is on the dashboard)
FINNHUB_API_KEY=

# FRED — keyed macro API (otherwise keyless CSV fallback is used).
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Ollama (optional overrides; auto-detects the first installed model)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.6:35b-a3b
